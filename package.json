    "@openzeppelin/contracts": "^5.3.0",
    "@tanstack/react-query": "^5.80.0",
    "ethers": "^6.14.0",
    "next": "^15.3.0",
    "pg": "^8.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.56.0",
    "viem": "^2.55.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@nomicfoundation/hardhat-toolbox": "^6.0.0",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "dotenv": "^16.5.0",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.3.0",
    "hardhat": "^2.26.0",
    "postcss": "^8.5.6",
    "prettier": "^3.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.0",
    "utf-8-validate": "^5.0.10"
