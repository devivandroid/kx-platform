{
  "name": "kx-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "site:start": "scripts\\windows\\start-site.cmd",
    "site:stop": "scripts\\windows\\stop-site.cmd",
    "site:restart": "scripts\\windows\\restart-site.cmd",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "qa:release": "node scripts/qa/release-smoke.mjs",
    "typecheck": "tsc --noEmit",
